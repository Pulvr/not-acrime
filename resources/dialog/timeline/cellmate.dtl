[style name="default_style"]
if {end_reached} == true:
	jump end
if {lock_solved} == true:
	jump lock_solved
if {has_key} == true:
	Cellmate: Don't you [shake rate=15 level=5][b]DARE[/b][/shake] use that!
	Cellmate: This is [shake rate=15 level=5][lspeed=.3][b] MY [/b][lspeed][/shake] escape plan.
	Cellmate: And I won't let you ruin it for me!
	[end_timeline]
if {talked_to_cellmate_1} == false:
	Cellmate: ... you want to break out of here? [pause=1.0] Good luck with that, —just keep me out of it.
	Cellmate: I’d rather sit here and wait for my execution than work myself to death in this camp.
	Cellmate: But I saw something in the toilet [pause=1.0] — why don't you try fishing it out? [pause=1.0] [shake rate=15 level=5][lspeed=.5]Hehe…[lspeed][/shake]
	set {talked_to_cellmate_1} = true
	[end_timeline]
elif {talked_to_cellmate_with_sharp} == true:
	Cellmate: You stink, go away!
	[end_timeline]
elif {has_sharp} == true:
	label has_sharp_label
	Cellmate: What, did you really take that out of there?!
	Cellmate: You sure do stink of it, though.[shake rate=30 level=6] HAHAHAHA!!![/shake]
	Cellmate: Now get off my back — this stink is unbearable.
	set {talked_to_cellmate_with_sharp} = true
	[end_timeline]
elif {talked_to_cellmate_1} == true:
	Cellmate: I saw something in the toilet [pause=1.0] — why don't you try fishing it out, [shake rate=15 level=5]hehe…[/shake]
	[end_timeline]
label lock_solved
Cellmate: You know that once you're out there, nothing is gonna change.
Cellmate: You would be better off, just accepting the facts!
Cellmate: But you're not gonna listen ... just buzz off and find out the hard way...
set {end_reached} = true
[end_timeline]
label end
Cellmate: Just leave
[end_timeline]
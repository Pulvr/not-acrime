; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="notAcrime"
run/main_scene="uid://dgftfyd3k8fyh"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://b2vjjfufwycpo"

[autoload]

Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={
"Cellmate": "res://resources/dialog/character/Cellmate.dch",
"Prisoner": "res://resources/dialog/character/Prisoner.dch"
}
directories/dtl_directory={
"cellmate": "res://resources/dialog/timeline/cellmate.dtl",
"cellmate2": "res://resources/dialog/timeline/cellmate2.dtl",
"sample_timeline": "res://resources/dialog/timeline/sample_timeline.dtl",
"second_timeline": "res://resources/dialog/style/second_timeline.dtl",
"welcome_timeline": "res://resources/dialog/timeline/welcome_timeline.dtl"
}
layout/style_directory={
"default_style": "res://resources/dialog/style/default_style.tres"
}
glossary/default_case_sensitive=true
layout/style_list=["res://resources/dialog/style/default_style.tres"]
layout/default_style=""
variables={
"dialog_played": false,
"first_conversation": true
}
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}
text/input_action="dialogic_default_action"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

[global_group]

item_for_pickup=""
interactable=""
talk_to=""

